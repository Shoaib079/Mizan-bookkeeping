# Database (PostgreSQL via docker-compose)
DATABASE_URL=postgresql+psycopg://mizan:mizan_dev@localhost:5432/mizan

# Bootstrap — local Postgres superuser to create mizan role/DBs (tests/dev)
DATABASE_ADMIN_URL=postgresql+psycopg://postgres@localhost:5432/postgres

# Frontend → API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Redis / Celery (backups scheduler)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Backups — local artifact dir when S3 is not configured
BACKUP_LOCAL_DIR=data/backups
BACKUP_SCHEDULE_HOUR=3
BACKUP_SCHEDULE_MINUTE=0
BACKUP_RETENTION_DAILY_DAYS=14
BACKUP_RETENTION_WEEKLY_WEEKS=8

# Off-site S3-compatible storage (SSE at rest). Leave bucket empty for local-only dev.
# BACKUP_S3_BUCKET=mizan-backups
# BACKUP_S3_PREFIX=mizan
# BACKUP_S3_ENDPOINT_URL=https://s3.example.com
# BACKUP_S3_REGION=eu-central-1
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=

# Mizan production environment catalog (Phase 12 Slice 12.2)
# Copy to your host secrets manager — never commit real values.
# See DEPLOY.md for provisioning steps.

# --- App ---
APP_ENV=production
AUTH_ENFORCEMENT=true
IDEMPOTENCY_ENFORCEMENT=true
CLERK_TEST_MODE=false

# --- Database (Neon / Supabase / managed Postgres) ---
# App role — RLS-enforced runtime queries
DATABASE_URL=postgresql+psycopg://mizan_app:CHANGE_ME@app-db.example.com:5432/mizan?sslmode=require
# Schema owner — Alembic migrations only (migrate_production.sh)
DATABASE_ADMIN_URL=postgresql+psycopg://mizan:CHANGE_ME@app-db.example.com:5432/postgres?sslmode=require

# --- Redis / Celery (Upstash or managed Redis) ---
REDIS_URL=rediss://default:CHANGE_ME@redis.example.com:6379/0
CELERY_BROKER_URL=rediss://default:CHANGE_ME@redis.example.com:6379/0
CELERY_RESULT_BACKEND=rediss://default:CHANGE_ME@redis.example.com:6379/1

# --- CORS (comma-separated browser origins — NOT localhost in production) ---
# Vercel production + optional preview URL
CORS_ORIGINS=https://app.example.com,https://staging.example.com

# --- Clerk (production instance — live keys only when APP_ENV=production) ---
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_AUDIENCE=pk_live_...
# JWT template MUST include claims: email, email_verified (see DEPLOY.md §6)

# --- Frontend (Vercel env) ---
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# --- Uploads (local disk or S3/R2 — P3) ---
# Set UPLOAD_STORAGE=s3 to persist receipt/invoice files off-site (reuses BACKUP_S3_* creds).
UPLOAD_DIR=/app/data/uploads
UPLOAD_STORAGE=s3
UPLOAD_S3_PREFIX=uploads

# --- Backups ---
BACKUP_LOCAL_DIR=/app/data/backups
BACKUP_SCHEDULE_HOUR=3
BACKUP_SCHEDULE_MINUTE=0
BACKUP_RETENTION_DAILY_DAYS=14
BACKUP_RETENTION_WEEKLY_WEEKS=8

# S3-compatible off-site backup (Cloudflare R2 / AWS S3)
BACKUP_S3_BUCKET=mizan-backups
BACKUP_S3_PREFIX=mizan
BACKUP_S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
BACKUP_S3_REGION=auto
BACKUP_S3_ACCESS_KEY_ID=CHANGE_ME
BACKUP_S3_SECRET_ACCESS_KEY=CHANGE_ME

# --- Observability (Slice 12.4) ---
# Optional — create a Sentry project and paste the DSN; API still boots without it
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# In-memory per-IP limit on API routes (default 60/min); not shared across Render instances
RATE_LIMIT_PER_MINUTE=60

# --- Optional: expense receipt vision OCR ---
# EXPENSE_RECEIPT_VISION_URL=
# EXPENSE_RECEIPT_VISION_API_KEY=
# EXPENSE_RECEIPT_VISION_MODEL=gpt-4o-mini
